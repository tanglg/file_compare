{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF 雷同性检测工具",
  "version": "1.0.0",
  "identifier": "com.local.pdf-similarity-detector",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF 雷同性检测工具",
        "width": 1360,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
